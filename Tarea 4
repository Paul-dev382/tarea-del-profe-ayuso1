using System;
using System.Diagnostics.CodeAnalysis;

namespace Arreglos_
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("calcular promedio de cinco numeros");
            int[] numeros = new int[5];

            int suma = 0;
            for (int i = 0; i < 5; i++)
            {
                Console.WriteLine($"ingrese el numero{i + 1}:");
                numeros[i] = int.Parse(Console.ReadLine());
                suma += numeros[i];
            }

            double promedio = (double)suma / 5;
            Console.WriteLine("\n numeros ingresados: ");
            Console.Write("   ");

            for (int i = 0; i < 5; i++)
            {
                Console.Write(numeros[i] + "   ");

            }
            Console.WriteLine($"\n\nresultado total:  {suma}");
            Console.WriteLine($"Promedio final:  {promedio:F2}");

            Console.WriteLine("\npresione cualquier tecla para salir...");
            Console.ReadLine();



        }
    }
}
